{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "theme": { "type": "string", "enum": ["dark", "light"] },
        "language": { "type": "string" },
        "totalBalance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents a single financial movement.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "type", "timestamp"]
    },
    "Target": {
      "title": "Financial Target",
      "description": "A savings goal or milestone.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "name": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["active", "completed"] }
      },
      "required": ["uid", "name", "targetAmount", "currentAmount"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's financial transactions"
    },
    "/users/{userId}/targets/{targetId}": {
      "schema": "Target",
      "description": "User's financial goals"
    }
  }
}
